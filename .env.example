# Copy this file to .env and fill in the real values.

# MongoDB Atlas connection string (contains the database password)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.example.mongodb.net/

# Database name (use a different one for testing, e.g. phonecircle_test)
PHONECIRCLE_DB_NAME=phonecircle

# Signs the login session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=
